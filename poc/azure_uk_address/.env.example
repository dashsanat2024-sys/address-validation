# ── Option A: Direct OpenAI (platform.openai.com key) ──
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# ── Option B: Azure OpenAI / Azure AI Foundry ──
LLM_PROVIDER=azure
# Foundry v1 (from portal "Keys and Endpoint" — include /openai/v1 if shown)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your-azure-resource-key
# Deployment NAME from Azure AI Studio → Deployments (not the model catalog id)
AZURE_OPENAI_DEPLOYMENT=Kimi-K2.6
# Classic Azure OpenAI only (omit /openai/v1 from endpoint):
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: override pricing (USD per 1M tokens) for cost report
# AZURE_INPUT_PRICE_PER_1M=0.15
# AZURE_OUTPUT_PRICE_PER_1M=0.60

# Postcodes.io (free, no key)
POSTCODES_IO_BASE=https://api.postcodes.io
