# Ollama — qwen2.5:7b is fastest on 16GB Mac; qwen3:8b works but slower (thinking disabled in code)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
# Max tokens for JSON response (lower = faster)
OLLAMA_NUM_PREDICT=512
# Seconds before Ollama call fails (avoids hanging forever)
OLLAMA_TIMEOUT=120
# Pre-load model when Flask starts (first batch row much faster)
OLLAMA_WARMUP=1

# Flask API
FLASK_PORT=5050
FLASK_DEBUG=1

# Address validator: postcodes_io (free) | local_first | ideal_postcodes (street-level, needs API key)
ADDRESS_VALIDATOR=postcodes_io
POSTCODES_IO_BASE=https://api.postcodes.io

# Local compressed UK address index (OpenAddressUK-style open data, KB-scale gzip)
# Build: python tools/build_local_address_index.py
LOCAL_ADDRESS_INDEX=data/local/uk_addresses.json.gz
LOCAL_ADDRESS_AUTO=1
LOCAL_ADDRESS_MIN_CONFIDENCE=0.55
LOCAL_POSTCODE_CONFIDENCE=0.35
LOCAL_SKIP_POSTCODES_IO=1
LOCAL_STREET_FIRST=1
LOCAL_INDEX_MAX_RECORDS=800

# Set to 1 to bypass external validators by default (Ollama-only validation + mapping)
ADDRESS_SKIP_VALIDATION=0

# Ideal Postcodes (https://ideal-postcodes.co.uk) — trial then paid
# When set, ADDRESS_VALIDATOR=ideal_postcodes enables street-level cleanse
IDEAL_POSTCODES_API_KEY=
IDEAL_POSTCODES_MIN_CONFIDENCE=0.75

# Azure OpenAI (optional — for cloud LLM provider in UI)
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/openai/v1
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=Kimi-K2.6
# Azure latency tuning (Kimi-K2.6 ~10-20s; gpt-4o-mini ~1-3s)
# AZURE_OPENAI_MAX_TOKENS=512
# AZURE_OPENAI_TIMEOUT=45

# RAG — retrieve similar corrections to guide LLM (Arthavi + Azure)
RAG_ENABLED=1
RAG_TOP_K=3
RAG_MAX_EXAMPLES=200
