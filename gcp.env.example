# Copy to .env for local deploy script, or set in Cloud Run console
GCP_PROJECT_ID=arthavi-492410
GCP_REGION=europe-west2
GCP_SERVICE_NAME=arthavi-address-validation

# Cloud defaults: postcode validation only (Ollama runs locally, not on Cloud Run)
ADDRESS_VALIDATOR=postcodes_io
CLOUD_DEFAULT_SKIP_LLM=1

# Optional — set for street-level validation on Cloud Run
# IDEAL_POSTCODES_API_KEY=

# Optional — if you run Ollama on a GCE VM, set its URL here
# OLLAMA_HOST=http://10.0.0.5:11434
# OLLAMA_MODEL=qwen3:8b
