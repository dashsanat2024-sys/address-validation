# Copy to .env for local deploy script, or set in Cloud Run console
GCP_PROJECT_ID=arthavi-492410
GCP_REGION=europe-west2
GCP_SERVICE_NAME=arthavi-address-validation

# Cloud: point at Ollama VM (run ./setup_ollama_vm.sh). Local Mac uses .env → localhost.
ADDRESS_VALIDATOR=postcodes_io

# Production Ollama (set by setup_ollama_vm.sh or manually)
# OLLAMA_HOST=http://YOUR_VM_IP:11434
# OLLAMA_MODEL=qwen3:8b
# CLOUD_DEFAULT_SKIP_LLM=0

# Fast mode only (no Ollama) — use when OLLAMA_HOST is not set
CLOUD_DEFAULT_SKIP_LLM=1
